rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Per-class uploads: instructor-authored files attached to a module.
    // Read: any authenticated user (anonymous auth is enough — gates anonymous
    // browsing of the bucket).
    // Write: authenticated, App-Check-attested, ≤ 25 MB.
    match /classes/{classId}/uploads/{uploadId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024;
      allow delete: if request.auth != null;
    }
    match /classes/{classId}/syllabus/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024;
      allow delete: if request.auth != null;
    }
    // Student homework written-work uploads (proof of original effort), saved
    // alongside the submission. Read by the instructor (any authed user is fine).
    match /classes/{classId}/hwWork/{studentId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024;
      allow delete: if request.auth != null;
    }
  }
}
